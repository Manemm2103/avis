PORT=3000
AVIS_HTTP_PORT=3000
AVIS_HTTPS_ENABLED=true
AVIS_HTTPS_PORT=3443
AVIS_HTTPS_HOSTNAME=bw-lx-02
AVIS_HTTPS_AUTO_SELF_SIGNED=true
# Optional statt selbstsigniertem Testzertifikat:
# AVIS_HTTPS_CERT_FILE=/data/certs/avis.crt
# AVIS_HTTPS_KEY_FILE=/data/certs/avis.key
AVIS_DATA_FILE=/data/avis.json
AVIS_DEFAULT_ADMIN_USER=admin
AVIS_DEFAULT_ADMIN_PASSWORD=bitte-aendern

MSSQL_HOST=sqlserver.example.local
MSSQL_PORT=1433
MSSQL_DATABASE=DeineDatenbank
MSSQL_USER=avis_readonly
MSSQL_PASSWORD=bitte-aendern
MSSQL_ENCRYPT=false
MSSQL_TRUST_SERVER_CERTIFICATE=true

# Die Standardabfrage ist im Code mit ABNUMMER, KAPA_TOUR usw. bereits vorbelegt.
# Optional: MSSQL_QUERY als einzeilige SQL setzen oder eine Datei in den Container mounten.
# MSSQL_QUERY="SELECT ... AS ABNUMMER, ... AS LIEFERTERMIN, ... AS KAPA_TOUR FROM ..."
MSSQL_QUERY=
MSSQL_QUERY_FILE=

# Die Tourliste ist ebenfalls vorbelegt. Optional kann sie hier ueberschrieben werden.
# MSSQL_TOURS_QUERY="SELECT TOX_Bezeichnung FROM ..."
MSSQL_TOURS_QUERY=
MSSQL_TOURS_QUERY_FILE=
